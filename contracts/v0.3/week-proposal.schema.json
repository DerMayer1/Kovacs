{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kovacs.local/contracts/v0.3/week-proposal.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "primary_outcome", "success_criteria", "competencies", "rationale", "warnings"],
  "properties": {
    "schema_version": { "const": "0.3.0" },
    "primary_outcome": { "type": "string", "minLength": 8, "maxLength": 500 },
    "success_criteria": { "type": "array", "minItems": 1, "maxItems": 5, "uniqueItems": true, "items": { "type": "string", "minLength": 4, "maxLength": 500 } },
    "competencies": { "type": "array", "minItems": 1, "maxItems": 3, "uniqueItems": true, "items": { "$ref": "#/$defs/competency" } },
    "rationale": { "type": "string", "minLength": 4, "maxLength": 1200 },
    "warnings": { "type": "array", "maxItems": 5, "items": { "type": "string", "minLength": 2, "maxLength": 400 } }
  },
  "$defs": {
    "competency": { "enum": ["software_design_implementation", "ai_systems", "debugging_operational_judgment", "architecture", "testing_reliability", "security_privacy", "product_judgment", "technical_communication", "leadership_leverage", "execution_ownership"] }
  }
}
