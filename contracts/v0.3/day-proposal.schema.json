{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kovacs.local/contracts/v0.3/day-proposal.schema.json",
  "title": "Kovacs V0.3 daily plan proposal",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "proposed_objective", "objective_changed", "success_criteria", "checkpoints", "rationale", "warnings"],
  "properties": {
    "schema_version": { "type": "string", "const": "0.3.0" },
    "proposed_objective": { "type": "string", "minLength": 4, "maxLength": 1000 },
    "objective_changed": { "type": "boolean" },
    "success_criteria": { "type": "array", "minItems": 1, "maxItems": 5, "uniqueItems": true, "items": { "type": "string", "minLength": 4, "maxLength": 500 } },
    "checkpoints": {
      "type": "array",
      "minItems": 2,
      "maxItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "evidence_required", "competency"],
        "properties": {
          "title": { "type": "string", "minLength": 3, "maxLength": 300 },
          "evidence_required": { "type": "string", "minLength": 3, "maxLength": 500 },
          "competency": { "$ref": "#/$defs/competency" }
        }
      }
    },
    "rationale": { "type": "string", "minLength": 4, "maxLength": 1200 },
    "warnings": { "type": "array", "maxItems": 5, "items": { "type": "string", "minLength": 2, "maxLength": 400 } }
  },
  "$defs": {
    "competency": { "type": "string", "enum": ["software_design_implementation", "ai_systems", "debugging_operational_judgment", "architecture", "testing_reliability", "security_privacy", "product_judgment", "technical_communication", "leadership_leverage", "execution_ownership"] }
  }
}
