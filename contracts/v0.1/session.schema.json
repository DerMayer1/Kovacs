{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kovacs.local/contracts/v0.1/session.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "session_id", "project", "task", "mode", "status", "started_at", "ended_at", "events"],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "session_id": { "type": "string", "pattern": "^ses_[a-zA-Z0-9_-]+$" },
    "project": { "type": "string", "minLength": 1 },
    "task": { "type": "string", "minLength": 1 },
    "mode": { "enum": ["training", "pair", "assessment"] },
    "status": { "enum": ["active", "completed"] },
    "started_at": { "type": "string", "format": "date-time" },
    "ended_at": { "type": ["string", "null"], "format": "date-time" },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["event_id", "occurred_at", "type", "request_id", "payload"],
        "properties": {
          "event_id": { "type": "string", "pattern": "^aud_[a-zA-Z0-9_-]+$" },
          "occurred_at": { "type": "string", "format": "date-time" },
          "type": { "enum": ["session_started", "request_accepted", "request_blocked", "gateway_failed", "response_rejected", "intervention_displayed", "session_completed"] },
          "request_id": { "type": ["string", "null"] },
          "payload": { "type": "object" }
        }
      }
    }
  }
}
