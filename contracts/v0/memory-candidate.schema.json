{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kovacs.local/contracts/v0/memory-candidate.schema.json",
  "title": "Kovacs V0 Memory Candidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "candidate_id",
    "memory_type",
    "claim",
    "epistemic_status",
    "source_event_ids",
    "confidence",
    "sensitivity",
    "retention",
    "expires_at",
    "evidence_reference",
    "requires_confirmation",
    "policy_version"
  ],
  "properties": {
    "candidate_id": { "type": "string", "pattern": "^mem_[a-z0-9_]+$" },
    "memory_type": {
      "enum": ["working", "episodic", "semantic", "evidence", "commitment", "pattern", "curriculum", "professional"]
    },
    "claim": { "type": "string", "minLength": 1 },
    "epistemic_status": { "enum": ["user_stated", "observed", "inferred", "verified"] },
    "source_event_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^evt_[a-z0-9_]+$" }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "sensitivity": { "enum": ["public", "internal", "sensitive"] },
    "retention": { "enum": ["ephemeral", "session", "30d", "90d", "until_review"] },
    "expires_at": { "type": ["string", "null"], "format": "date-time" },
    "evidence_reference": { "type": ["string", "null"] },
    "requires_confirmation": { "type": "boolean" },
    "policy_version": { "const": "v0.1.0" }
  },
  "allOf": [
    {
      "if": { "properties": { "memory_type": { "const": "evidence" } }, "required": ["memory_type"] },
      "then": {
        "properties": {
          "epistemic_status": { "const": "verified" },
          "evidence_reference": { "type": "string", "minLength": 1 }
        }
      }
    },
    {
      "if": { "properties": { "retention": { "enum": ["30d", "90d"] } }, "required": ["retention"] },
      "then": { "properties": { "expires_at": { "type": "string", "format": "date-time" } } }
    }
  ]
}
