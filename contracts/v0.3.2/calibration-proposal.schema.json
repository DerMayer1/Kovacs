{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kovacs.local/contracts/v0.3.2/calibration-proposal.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "mission_title", "mission_success_criteria", "weekly_outcome", "weekly_success_criteria", "weekly_competencies", "rationale", "warnings", "interpreted_profile", "assumptions", "clarification_questions"],
  "properties": {
    "schema_version": { "type": "string", "const": "0.3.0" },
    "mission_title": { "type": "string", "minLength": 8, "maxLength": 500 },
    "mission_success_criteria": { "type": "array", "minItems": 2, "maxItems": 6, "items": { "type": "string", "minLength": 4, "maxLength": 500 } },
    "weekly_outcome": { "type": "string", "minLength": 8, "maxLength": 500 },
    "weekly_success_criteria": { "type": "array", "minItems": 1, "maxItems": 5, "items": { "type": "string", "minLength": 4, "maxLength": 500 } },
    "weekly_competencies": { "type": "array", "minItems": 1, "maxItems": 3, "items": { "$ref": "#/$defs/competency" } },
    "rationale": { "type": "string", "minLength": 4, "maxLength": 1200 },
    "warnings": { "type": "array", "maxItems": 5, "items": { "type": "string", "minLength": 2, "maxLength": 400 } },
    "interpreted_profile": { "type": "object", "additionalProperties": false, "required": ["current_position", "available_hours_per_week", "active_projects", "growth_edges", "desired_outcome"], "properties": {
      "current_position": { "$ref": "#/$defs/text_value" },
      "available_hours_per_week": { "$ref": "#/$defs/number_value" },
      "active_projects": { "$ref": "#/$defs/list_value" },
      "growth_edges": { "$ref": "#/$defs/list_value" },
      "desired_outcome": { "$ref": "#/$defs/text_value" }
    } },
    "assumptions": { "type": "array", "maxItems": 8, "items": { "type": "string" } },
    "clarification_questions": { "type": "array", "maxItems": 2, "items": { "type": "string" } }
  },
  "$defs": {
    "source": { "type": "string", "enum": ["explicit", "inferred", "unknown", "confirmed"] },
    "text_value": { "type": "object", "additionalProperties": false, "required": ["value", "source", "confidence", "rationale"], "properties": { "value": { "type": ["string", "null"] }, "source": { "$ref": "#/$defs/source" }, "confidence": { "type": "number", "minimum": 0, "maximum": 1 }, "rationale": { "type": "string" } } },
    "number_value": { "type": "object", "additionalProperties": false, "required": ["value", "source", "confidence", "rationale"], "properties": { "value": { "type": ["number", "null"] }, "source": { "$ref": "#/$defs/source" }, "confidence": { "type": "number", "minimum": 0, "maximum": 1 }, "rationale": { "type": "string" } } },
    "list_value": { "type": "object", "additionalProperties": false, "required": ["value", "source", "confidence", "rationale"], "properties": { "value": { "type": ["array", "null"], "items": { "type": "string" } }, "source": { "$ref": "#/$defs/source" }, "confidence": { "type": "number", "minimum": 0, "maximum": 1 }, "rationale": { "type": "string" } } },
    "competency": { "type": "string", "enum": ["software_design_implementation", "ai_systems", "debugging_operational_judgment", "architecture", "testing_reliability", "security_privacy", "product_judgment", "technical_communication", "leadership_leverage", "execution_ownership"] }
  }
}
