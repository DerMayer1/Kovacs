{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kovacs.local/contracts/v0.3.2/context-frame.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "context_id", "occurred_at", "application", "project", "activity", "artifact", "visible_intent", "active_checkpoint", "privacy_classification", "confidence", "ambiguity", "signal_sources", "changed_fields", "text_digest"],
  "properties": {
    "schema_version": { "type": "string", "const": "0.3.2" },
    "context_id": { "type": "string", "pattern": "^ctx_[a-f0-9]{32}$" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "application": { "type": "string", "minLength": 1, "maxLength": 300 },
    "project": { "type": ["string", "null"], "maxLength": 2048 },
    "activity": { "type": "string", "minLength": 1, "maxLength": 200 },
    "artifact": { "type": ["string", "null"], "maxLength": 500 },
    "visible_intent": { "type": "string", "minLength": 1, "maxLength": 800 },
    "active_checkpoint": { "type": ["string", "null"], "maxLength": 500 },
    "privacy_classification": { "type": "string", "enum": ["authorized", "restricted", "unknown"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "ambiguity": { "type": "array", "maxItems": 8, "items": { "type": "string" } },
    "signal_sources": { "type": "array", "items": { "type": "string", "enum": ["active_window", "accessibility", "ocr", "operating_state", "memory"] } },
    "changed_fields": { "type": "array", "items": { "type": "string" } },
    "text_digest": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" }
  }
}
