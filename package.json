{
  "name": "kovacs",
  "version": "0.3.3",
  "private": true,
  "type": "module",
  "description": "A local-first, evidence-driven Staff Engineer operating system powered by Codex CLI.",
  "engines": {
    "node": ">=22.12.0"
  },
  "bin": {
    "kovacs": "dist/src/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/src/cli.js",
    "test": "node --import tsx --test test/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "v0:validate": "tsx v0/validate.ts",
    "v01:validate": "tsx v01/validate.ts",
    "v01:smoke": "tsx v01/smoke.ts",
    "v02:validate": "tsx v02/validate.ts",
    "v02:smoke": "tsx v02/smoke.ts",
    "v03:validate": "tsx v03/validate.ts",
    "v03:smoke": "tsx v03/smoke.ts",
    "v031:validate": "tsx v031/validate.ts",
    "v031:smoke": "tsx v031/smoke.ts",
    "v031:live": "tsx v031/live.ts",
    "v032:validate": "tsx v032/validate.ts",
    "v032:smoke": "tsx v032/smoke.ts",
    "v032:live": "tsx v032/live.ts",
    "v033:validate": "tsx v033/validate.ts",
    "v033:smoke": "tsx v033/smoke.ts",
    "v033:evaluate": "tsx v033/evaluate-retrieval.ts",
    "pet:v02": "npm run build && electron dist/src/v02/electron/main.js",
    "pet": "npm run build && electron dist/src/v03/electron/main.js"
  },
  "dependencies": {
    "get-windows": "9.3.0",
    "ajv": "latest",
    "ajv-formats": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "electron": "43.1.1",
    "tsx": "latest",
    "typescript": "latest"
  },
  "overrides": {
    "tar": "7.5.20"
  }
}
