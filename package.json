{
  "name": "kovacs",
  "version": "0.3.3",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "description": "A local-first, evidence-driven Staff Engineer operating system powered by Codex CLI.",
  "engines": {
    "node": ">=22.12.0"
  },
  "bin": {
    "kovacs": "dist/src/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "ci": "npm run release:validate",
    "dev": "tsx src/cli.ts",
    "start": "node dist/src/cli.js",
    "test": "node --import tsx --test test/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "release:validate": "tsx scripts/releases/v0.3.3/validate.ts",
    "release:smoke": "tsx scripts/releases/v0.3.3/smoke.ts",
    "retrieval:evaluate": "tsx scripts/releases/v0.3.3/evaluate-retrieval.ts",
    "acceptance:live": "tsx scripts/releases/v0.3.2/live.ts",
    "v0:validate": "tsx scripts/releases/v0/validate.ts",
    "v01:validate": "tsx scripts/releases/v0.1/validate.ts",
    "v01:smoke": "tsx scripts/releases/v0.1/smoke.ts",
    "v02:validate": "tsx scripts/releases/v0.2/validate.ts",
    "v02:smoke": "tsx scripts/releases/v0.2/smoke.ts",
    "v03:validate": "tsx scripts/releases/v0.3/validate.ts",
    "v03:smoke": "tsx scripts/releases/v0.3/smoke.ts",
    "v031:validate": "tsx scripts/releases/v0.3.1/validate.ts",
    "v031:smoke": "tsx scripts/releases/v0.3.1/smoke.ts",
    "v031:live": "tsx scripts/releases/v0.3.1/live.ts",
    "v032:validate": "tsx scripts/releases/v0.3.2/validate.ts",
    "v032:smoke": "tsx scripts/releases/v0.3.2/smoke.ts",
    "v032:live": "tsx scripts/releases/v0.3.2/live.ts",
    "v033:validate": "npm run release:validate",
    "v033:smoke": "npm run release:smoke",
    "v033:evaluate": "npm run retrieval:evaluate",
    "ambient:legacy": "npm run build && electron dist/src/interfaces/desktop/ambient-companion.js",
    "pet:v02": "npm run ambient:legacy",
    "kovacs": "npm run build && electron dist/src/interfaces/desktop/main.js",
    "pet": "npm run kovacs"
  },
  "dependencies": {
    "get-windows": "9.3.0",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "electron": "43.1.1",
    "tsx": "4.23.1",
    "typescript": "7.0.2"
  },
  "overrides": {
    "tar": "7.5.20"
  }
}
